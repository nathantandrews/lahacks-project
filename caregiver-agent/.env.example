# ASI-1 Mini API key — get from https://asi1.ai/dashboard/api-keys
ASI1_API_KEY=your_asi1_api_key_here

# Unique seed phrase for your agent (keep secret — determines agent address)
AGENT_SEED=caregiver-agent-unique-seed-phrase-lahacks-2026

# Port the agent listens on locally
AGENT_PORT=8001

# Public endpoint URL — update this after running ngrok
# Example: AGENT_ENDPOINT=https://abc123.ngrok-free.app/submit
AGENT_ENDPOINT=http://localhost:8001/submit
