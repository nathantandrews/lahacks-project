# MongoDB connection string — use MongoDB Atlas free tier for the hackathon
# Get one at: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=caregiver_hub

# ASI-1 Mini API key — used by the /api/ai/chat endpoint for the frontend widget
# Get one at: https://asi1.ai/dashboard/api-keys
ASI1_API_KEY=your_asi1_api_key_here

# CaregiverAgent base URL (update if agent is running on a different port)
AGENT_BASE_URL=http://localhost:8001
