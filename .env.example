# ── ngrok (required for Docker Compose) ──────────────────────────────────────
# Get your authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Optional: set a static ngrok domain so the URL never changes.
# Free accounts get one static domain at: https://dashboard.ngrok.com/domains
# If left blank, ngrok assigns a random URL each run (you'll need to update
# AGENT_ENDPOINT in caregiver-agent/.env and re-register on Agentverse).
# Include https:// prefix — e.g. https://your-domain.ngrok-free.dev
NGROK_DOMAIN=https://portable-cylinder-showdown.ngrok-free.dev
